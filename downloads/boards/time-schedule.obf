{
  "id": "tb-time-schedule",
  "name": "Time and Schedule",
  "locale": "en",
  "version": "1.0.0",
  "author": "Talking Buttons SLP/AT Team",
  "grid": { "rows": 3, "columns": 4 },
  "buttons": [
    { "label": "Now" }, { "label": "Later" }, { "label": "Soon" }, { "label": "Today" },
    { "label": "Tomorrow" }, { "label": "Morning" }, { "label": "Afternoon" }, { "label": "Night" },
    { "label": "First" }, { "label": "Then" }, { "label": "Finished" }, { "label": "Wait" }
  ]
}
